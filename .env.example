# =============================================================================
# Universal Point Cloud Viewer - Environment Configuration
# Copy this file to ".env.local" and adjust paths for your machine.
# =============================================================================

# ---------------------------------------------------------------------------
# Executable paths
# ---------------------------------------------------------------------------
# Full path to the PDAL executable.
# Windows (conda/OSGeo4W install) example:
#   PDAL_BIN=C:\Users\you\miniconda3\envs\pdal-env\Library\bin\pdal.exe
# If PDAL is already on your PATH, "pdal" alone works.
PDAL_BIN=pdal

# Full path to the PotreeConverter executable.
# Windows example:
#   POTREE_CONVERTER_BIN=C:\Tools\PotreeConverter\PotreeConverter.exe
POTREE_CONVERTER_BIN=PotreeConverter

# ---------------------------------------------------------------------------
# Storage configuration
# ---------------------------------------------------------------------------
# Absolute or relative path to the storage root. Defaults to "./storage"
# relative to the project root if not set.
STORAGE_ROOT=./storage

# ---------------------------------------------------------------------------
# Upload limits
# ---------------------------------------------------------------------------
# Maximum accepted upload size in bytes. Default: 2147483648 (2 GB)
MAX_UPLOAD_SIZE_BYTES=2147483648

# ---------------------------------------------------------------------------
# Process execution
# ---------------------------------------------------------------------------
# Maximum time (ms) a single PDAL or PotreeConverter process may run before
# being killed. Default: 1800000 (30 minutes). Increase for very large scans.
PROCESS_TIMEOUT_MS=1800000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# One of: debug | info | warn | error
LOG_LEVEL=info
